@startuml
title Sistem Informasi Persediaan Rumah Makan Aisyah Ngabang

left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor "Pengguna" as user

rectangle "Sistem Informasi Persediaan" {

  usecase "Login" as UC_Login
  usecase "Logout" as UC_Logout
  usecase "Lihat Dashboard" as UC_Dashboard
  usecase "Kelola Data Master" as UC_Master
  usecase "Catat Barang Masuk" as UC_Masuk
  usecase "Catat Barang Keluar" as UC_Keluar
  usecase "Lihat Buku Besar" as UC_Ledger
  usecase "Ekspor Laporan" as UC_Ekspor

}

' ─── Relasi Aktor ───
user --> UC_Login
user --> UC_Logout
user --> UC_Dashboard
user --> UC_Master
user --> UC_Masuk
user --> UC_Keluar
user --> UC_Ledger
user --> UC_Ekspor

' ─── <<include>>: Semua fitur butuh Login ───
UC_Dashboard ..> UC_Login : <<include>>
UC_Master    ..> UC_Login : <<include>>
UC_Masuk     ..> UC_Login : <<include>>
UC_Keluar    ..> UC_Login : <<include>>
UC_Ledger    ..> UC_Login : <<include>>
UC_Ekspor    ..> UC_Login : <<include>>

' ─── <<extend>>: Ekspor adalah perluasan dari Buku Besar ───
UC_Ekspor ..> UC_Ledger : <<extend>>

@enduml
