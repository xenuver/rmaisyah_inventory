# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Salin file ini menjadi .env dan isi nilainya
# JANGAN commit file .env ke repository!
# ─────────────────────────────────────────────────────────────────────────────

# Django Security
SECRET_KEY=

# Debug mode (set ke False di production)
DEBUG=False

# Host yang diizinkan (pisahkan dengan koma, contoh: yourdomain.com,www.yourdomain.com)
ALLOWED_HOSTS=

# CSRF trusted origins (pisahkan dengan koma, contoh: https://yourdomain.com)
CSRF_TRUSTED_ORIGINS=

# ─── Database ────────────────────────────────────────────────────────────────
DB_NAME=rmaisyah_inventory
DB_USER=postgres
DB_PASSWORD=postgres123
DB_HOST=db
DB_PORT=5432

# ─── Django Superuser (dibuat otomatis saat deploy pertama) ──────────────────
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=admin123
DJANGO_SUPERUSER_EMAIL=admin@admin.com

# ─── Port ────────────────────────────────────────────────────────────────────
PORT=8000
